name: ${PROJECT}
description: ${DESCRIPTION}
runtime: yaml
template:
  description: K8s application deployed to shared cluster.  

config:
  # This project is set up so kubconfig is provided via an ESC environment that uses a stack reference to get the kubeconfig from a base K8s cluster stack.
  kubeconfig:
    secret: true

resources: 
  # Create a K8s provider using the kubeconfig retrieved as a stack reference above.
  k8sProvider: 
    type: pulumi:providers:kubernetes
    properties:
      kubeconfig: ${kubeconfig}
      deleteUnreachable: true

  # Create K8s namespace in which to deploy the services
  guestbook-yaml-ns:
    type: kubernetes:core/v1:Namespace
    options:
      provider: ${k8sProvider}
      
  # Create K8s deployments using the custom k8s-servicedeployment multilanguage package
  redis-leader:
    type: k8sapp:ServiceDeployment
    properties:
      namespace: ${guestbook-yaml-ns.metadata.name}
      image: redis
      port: 6379
    options:
      provider: ${k8sProvider}
      pluginDownloadURL: "github://api.github.com/pulumi-pequod/pequod-mlc-k8sapp"
  redis-replica: 
    type: k8sapp:ServiceDeployment
    properties:
      namespace: ${guestbook-yaml-ns.metadata.name}
      image: pulumi/guestbook-redis-replica
      port: 6379
    options:
      provider: ${k8sProvider}
      pluginDownloadURL: "github://api.github.com/pulumi-pequod/pequod-mlc-k8sapp"
  frontend: 
    type: k8sapp:ServiceDeployment
    properties:
      namespace: ${guestbook-yaml-ns.metadata.name}
      image: pulumi/guestbook-php-redis
      port: 80
      replicas: 3
      allocateIpAddress: true
    options:
      provider: ${k8sProvider}
      pluginDownloadURL: "github://api.github.com/pulumi-pequod/pequod-mlc-k8sapp"

  # Set up stack config items
  stacksettings:
    type: stackmgmt:StackSettings 
    options:
      pluginDownloadURL: "github://api.github.com/pulumi-pequod/pequod-mlc-stackmgmt"
      # optionally add a specific version
      # version: v3.2.1

outputs:
  frontEndUrl: http://${frontend.ipAddress}
